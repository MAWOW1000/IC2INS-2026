---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { conference, contactInfo } from '../../lib/ic2ins-data.js';

const title = `Contact Us | ${conference.shortName}`;
const description =
  'Contact the IC2INS-2026 organizing team for conference enquiries, author support, registration questions, and submission information.';
const contactMailHref = `mailto:${contactInfo.email}`;
---

<BaseLayout
  title={title}
  description={description}
  canonical={new URL('/contact-us', Astro.site).toString()}
>
  <div id="content" class="col-full business">
    <div id="main-sidebar-container">
      <section id="main" style="width: 98%;">
        <article class="post-2 page type-page status-publish hentry">
          <section class="entry">
            <div class="woo-sc-hr" style="border-bottom: 6px solid #efefef; width: 100%;">
              <h2>Contact Us</h2>
            </div>
            <p><strong>Contact Person:</strong> {contactInfo.name}</p>
            <p><strong>Email:</strong> <a href={contactMailHref}>{contactInfo.email}</a></p>
            <p><strong>Phone:</strong> {contactInfo.phone}</p>
          </section>
          <div class="fix"></div>
        </article>
      </section>
    </div>
  </div>
</BaseLayout>
