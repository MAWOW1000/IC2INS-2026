---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { conference, technicalProgramCommittee } from '../../../lib/ic2ins-data.js';

const title = `Technical Program Committee | ${conference.shortName}`;
const description = `${conference.shortName} technical program committee members.`;
---

<BaseLayout
  title={title}
  description={description}
  canonical={new URL('/committee/technical-program-committee', Astro.site).toString()}
>
  <div id="content" class="col-full business">
    <div id="main-sidebar-container">
      <section id="main" style="width: 98%;">
        <article class="post-2 page type-page status-publish hentry">
          <section class="entry">
            <div class="woo-sc-hr" style="border-bottom: 6px solid #efefef; width: 100%;">
              <h2>Technical Program Committee</h2>
            </div>
            <ul>
              {technicalProgramCommittee.map((member) => <li>{member}</li>)}
            </ul>
          </section>
          <div class="fix"></div>
        </article>
      </section>
    </div>
  </div>
</BaseLayout>
