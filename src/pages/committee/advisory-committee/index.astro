---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { advisoryCommittee, conference } from '../../../lib/ic2ins-data.js';

const title = `Advisory Committee | ${conference.shortName}`;
const description = 'IC2INS-2026 advisory committee members.';
---

<BaseLayout
  title={title}
  description={description}
  canonical={new URL('/committee/advisory-committee', Astro.site).toString()}
>
  <div id="content" class="col-full business">
    <div id="main-sidebar-container">
      <section id="main" style="width: 98%;">
        <article class="post-2 page type-page status-publish hentry">
          <section class="entry">
            <div class="woo-sc-hr" style="border-bottom: 6px solid #efefef; width: 100%;">
              <h2>Advisory Committee</h2>
            </div>
            <ul>
              {advisoryCommittee.map((member) => <li>{member}</li>)}
            </ul>
          </section>
          <div class="fix"></div>
        </article>
      </section>
    </div>
  </div>
</BaseLayout>
