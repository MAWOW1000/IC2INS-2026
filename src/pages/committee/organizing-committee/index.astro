---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { conference, organizingCommittee } from '../../../lib/ic2ins-data.js';

const title = `Organizing Committee | ${conference.shortName}`;
const description = `${conference.shortName} organizing committee members.`;
---

<BaseLayout
  title={title}
  description={description}
  canonical={new URL('/committee/organizing-committee', Astro.site).toString()}
>
  <div id="content" class="col-full business">
    <div id="main-sidebar-container">
      <section id="main" style="width: 98%;">
        <article class="post-2 page type-page status-publish hentry">
          <section class="entry">
            <div class="woo-sc-hr" style="border-bottom: 6px solid #efefef; width: 100%;">
              <h2>Organizing Committee</h2>
            </div>
            {
              organizingCommittee.map((group) => (
                <section>
                  <h3>{group.role}</h3>
                  <ul>
                    {group.members.map((member) => (
                      <li>{member}</li>
                    ))}
                  </ul>
                </section>
              ))
            }
          </section>
          <div class="fix"></div>
        </article>
      </section>
    </div>
  </div>
</BaseLayout>
