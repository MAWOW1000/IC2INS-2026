---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { conference, importantDates } from '../../../lib/ic2ins-data.js';

const title = `Important Dates | ${conference.shortName}`;
const description = `Important ${conference.shortName} dates for submission, notification, registration, and conference attendance.`;
---

<BaseLayout
  title={title}
  description={description}
  canonical={new URL('/author-info/important-dates', Astro.site).toString()}
>
  <div id="content" class="col-full business">
    <div id="main-sidebar-container">
      <section id="main" style="width: 98%;">
        <article class="post-2 page type-page status-publish hentry">
          <section class="entry">
            <div class="woo-sc-hr" style="border-bottom: 6px solid #efefef; width: 100%;">
              <h2>Important Dates</h2>
            </div>
            <table border="1" width="100%">
              <thead>
                <tr>
                  <th align="left">Task</th>
                  <th align="left">Important Date</th>
                </tr>
              </thead>
              <tbody>
                {
                  importantDates.map((row) => (
                    <tr>
                      <td>{row.task}</td>
                      <td>{row.date}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </section>
          <div class="fix"></div>
        </article>
      </section>
    </div>
  </div>
</BaseLayout>
