---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { conference, tracks } from '../../../lib/ic2ins-data.js';

const title = `Track Details | ${conference.shortName}`;
const description =
  'IC2INS-2026 track details covering artificial intelligence, advanced networked systems, machine vision, IoT, blockchain, cloud-edge-fog computing, and smart cities.';
---

<BaseLayout
  title={title}
  description={description}
  canonical={new URL('/call-for-papers/track-details', Astro.site).toString()}
>
  <div id="content" class="col-full business">
    <div id="main-sidebar-container">
      <section id="main" style="width: 98%;">
        <article class="post-2 page type-page status-publish hentry">
          <section class="entry">
            <div class="woo-sc-hr" style="border-bottom: 6px solid #efefef; width: 100%;">
              <h2>Track Details</h2>
            </div>
            {
              tracks.map((track) => (
                <section>
                  <h3>{track.title}</h3>
                  <ul>
                    {track.topics.map((topic) => (
                      <li>{topic}</li>
                    ))}
                  </ul>
                </section>
              ))
            }
          </section>
          <div class="fix"></div>
        </article>
      </section>
    </div>
  </div>
</BaseLayout>
