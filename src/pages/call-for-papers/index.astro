---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { conference, callForPapersIntro } from '../../lib/ic2ins-data.js';

const title = `Call for Papers | ${conference.shortName}`;
const description =
  'Submit original research to IC2INS-2026 tracks covering artificial intelligence, advanced networked systems, machine vision, IoT, blockchain, cloud-edge-fog computing, and smart cities.';
const highlightedPhrase = 'Computational Intelligence and Networked Systems (IC2INS-2026).';
const [introBeforeHighlight, introAfterHighlight = ''] =
  callForPapersIntro.split(highlightedPhrase);
---

<BaseLayout
  title={title}
  description={description}
  canonical={new URL('/call-for-papers', Astro.site).toString()}
>
  <div id="content" class="col-full business">
    <div id="main-sidebar-container">
      <section id="main" style="width: 98%;">
        <article class="post-2 page type-page status-publish hentry">
          <section class="entry">
            <div class="woo-sc-hr" style="border-bottom: 6px solid #efefef; width: 100%;">
              <h2>Call for Papers</h2>
              <p align="justify">
                {introBeforeHighlight}<strong>{highlightedPhrase}</strong>{introAfterHighlight}
              </p>
            </div>
          </section>
          <div class="fix"></div>
        </article>
      </section>
    </div>
  </div>
</BaseLayout>
