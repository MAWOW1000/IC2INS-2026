---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { conference, cmtAcknowledgement } from '../../lib/ic2ins-data.js';

const title = `CMT Acknowledgement | ${conference.shortName}`;
const description = `${conference.shortName} acknowledgement for use of the Microsoft Conference Management Toolkit service for paper submission and review workflows.`;
---

<BaseLayout
  title={title}
  description={description}
  canonical={new URL('/cmt-acknowledgement', Astro.site).toString()}
>
  <div id="content" class="col-full business">
    <div id="main-sidebar-container">
      <section id="main" style="width: 98%;">
        <article class="post-2 page type-page status-publish hentry">
          <section class="entry">
            <div class="woo-sc-hr" style="border-bottom: 6px solid #efefef; width: 100%;">
              <h2>CMT Acknowledgement</h2>
              <p align="justify">{cmtAcknowledgement}</p>
            </div>
          </section>
          <div class="fix"></div>
        </article>
      </section>
    </div>
  </div>
</BaseLayout>
