---
import Header from '../components/Header.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const {
  title = 'WC2IR-2026 | Computational Intelligence and Robotics',
  description = 'World Conference on Computational Intelligence and Robotics (WC2IR-2026).',
  canonical,
  image = '/site/images/wc2ir-banner-ai.jpg',
  keywords = 'WC2IR 2026, computational intelligence conference, robotics conference, artificial intelligence conference, autonomous systems, IoT, intelligent perception, automation',
  structuredData,
} = Astro.props;

const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const imageUrl = new URL(image, Astro.site).toString();
const structuredDataJson = structuredData
  ? JSON.stringify(structuredData).replace(/</g, '\\u003c')
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="WC2IR-2026 Organizing Committee" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#1f66d1" />
    <meta name="google-site-verification" content="krSndegzjSfslMoGTbShbrf0Tuub5iS0DZ-DtIDFs-c" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="WC2IR-2026" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content="WC2IR-2026 conference website banner" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    {structuredDataJson && <script type="application/ld+json" set:html={structuredDataJson} />}
    <link rel="icon" href="/site/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/site/favicon.png" />
    <link rel="apple-touch-icon" href="/site/favicon.png" />
    <link rel="stylesheet" href="/site/css/style.css" />
    <link rel="stylesheet" href="/site/css/colorbox.css" />
    <link rel="stylesheet" href="/site/css/font-awesome.min.css" />
    <link rel="stylesheet" href="/site/css/shortcodes.css" />
    <link rel="stylesheet" href="/site/css/custom.css" />
  </head>
  <body
    class="home page-template page-template-template-biz page-template-template-biz-php page page-id-2 chrome alt-style-default two-col-left width-960 two-col-left-960"
  >
    <div id="wrapper">
      <div id="inner-wrapper">
        <h3 class="nav-toggle icon">
          <a href="#navigation" aria-controls="navigation" aria-expanded="false">Navigation</a>
        </h3>
        <Header />
        <Navigation />
        <slot />
        <Footer />
      </div>
    </div>
    <div class="fix"></div>
  </body>
</html>
